# Web server
CHORDCRAFT_WEB_HOST=127.0.0.1
CHORDCRAFT_WEB_PORT=7862

# External LLM / audio-language-model inference service.
# AI-ChordCraft expects a /generate endpoint compatible with the request format used by SGLang-style services.
CHORDCRAFT_BACKEND=sglang
CHORDCRAFT_SGLANG_BASE_URL=http://127.0.0.1:30000
CHORDCRAFT_SGLANG_THINKING_BASE_URL=http://127.0.0.1:30000
CHORDCRAFT_SGLANG_INSTRUCT_BASE_URL=http://127.0.0.1:30001
CHORDCRAFT_SGLANG_API_KEY=your-api-key
CHORDCRAFT_SGLANG_MODEL_NAME=your-model-name
CHORDCRAFT_REQUEST_TIMEOUT=600

# Optional local MOSS-Music + SGLang runtime. This is a recommended local LLM setup, not required.
CHORDCRAFT_LLM_RUNTIME_ROOT=./third_party/MOSS-Music
CHORDCRAFT_SGLANG_WORKDIR=./third_party/MOSS-Music/sglang
CHORDCRAFT_SGLANG_THINKING_MODEL_PATH=./third_party/MOSS-Music/model/MOSS-Music-8B-Thinking
CHORDCRAFT_SGLANG_INSTRUCT_MODEL_PATH=./third_party/MOSS-Music/model/MOSS-Music-8B-Instruct
CHORDCRAFT_SGLANG_THINKING_PORT=30000
CHORDCRAFT_SGLANG_INSTRUCT_PORT=30001
CHORDCRAFT_SGLANG_THINKING_CUDA_VISIBLE_DEVICES=0
CHORDCRAFT_SGLANG_INSTRUCT_CUDA_VISIBLE_DEVICES=1
CHORDCRAFT_SGLANG_EXTRA_ARGS=

# SongFormer structure segmentation service.
# AI-ChordCraft calls POST ${CHORDCRAFT_SONGFORMER_BASE_URL}/api/songformer/segment.
CHORDCRAFT_SONGFORMER_BASE_URL=http://127.0.0.1:8080
CHORDCRAFT_SONGFORMER_TIMEOUT=900

# Optional local SongFormer runtime, only used when structure_engine=songformer-local.
CHORDCRAFT_SONGFORMER_ROOT=./third_party/SongFormer
SONGFORMER_MODEL_NAME=SongFormer
SONGFORMER_CHECKPOINT=src/SongFormer/ckpts/SongFormer.safetensors
SONGFORMER_CONFIG=src/SongFormer/configs/SongFormer.yaml

# Automatic chord-recognition runtime/model directory.
CHORDCRAFT_ACR_MODEL_DIR=./third_party/acr_model
# Optional direct checkpoint URLs used by scripts/prepare_third_party.sh.
# If unset, place the two checkpoint files directly under CHORDCRAFT_ACR_MODEL_DIR/checkpoints.
CHORDCRAFT_ACR_PL_CHECKPOINT_URL=
CHORDCRAFT_ACR_SL_CHECKPOINT_URL=

# Optional explicit ffmpeg/ffprobe paths.
CHORDCRAFT_FFMPEG=
CHORDCRAFT_FFPROBE=
