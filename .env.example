# Web server
CHORDCRAFT_WEB_HOST=127.0.0.1
CHORDCRAFT_WEB_PORT=7862

# MOSS-Music / audio LLM inference service.
# The demo expects an SGLang-compatible /generate endpoint.
CHORDCRAFT_BACKEND=sglang
CHORDCRAFT_SGLANG_BASE_URL=http://127.0.0.1:30000
CHORDCRAFT_SGLANG_THINKING_BASE_URL=http://127.0.0.1:30000
CHORDCRAFT_SGLANG_INSTRUCT_BASE_URL=http://127.0.0.1:30001
CHORDCRAFT_SGLANG_API_KEY=
CHORDCRAFT_REQUEST_TIMEOUT=600

# Optional helper script defaults for starting MOSS-Music with SGLang.
# By default, scripts/start_moss_music_sglang.sh assumes this demo sits next to MOSS-Music.
CHORDCRAFT_MOSS_MUSIC_ROOT=../MOSS-Music
CHORDCRAFT_SGLANG_WORKDIR=../MOSS-Music/sglang
CHORDCRAFT_MOSS_THINKING_MODEL_PATH=../MOSS-Music/model/MOSS-Music-8B-Thinking
CHORDCRAFT_MOSS_INSTRUCT_MODEL_PATH=../MOSS-Music/model/MOSS-Music-8B-Instruct
CHORDCRAFT_MOSS_THINKING_PORT=30000
CHORDCRAFT_MOSS_INSTRUCT_PORT=30001
CHORDCRAFT_MOSS_THINKING_CUDA_VISIBLE_DEVICES=0
CHORDCRAFT_MOSS_INSTRUCT_CUDA_VISIBLE_DEVICES=1
CHORDCRAFT_MOSS_SERVE_MODE=dual
CHORDCRAFT_SGLANG_EXTRA_ARGS=
CHORDCRAFT_LOG_DIR=./logs

# SongFormer structure segmentation service.
# The demo calls POST ${CHORDCRAFT_SONGFORMER_BASE_URL}/api/songformer/segment.
CHORDCRAFT_SONGFORMER_BASE_URL=http://127.0.0.1:8080
CHORDCRAFT_SONGFORMER_TIMEOUT=900

# Optional local SongFormer runtime, only used when structure_engine=songformer-local.
CHORDCRAFT_SONGFORMER_ROOT=
SONGFORMER_MODEL_NAME=SongFormer
SONGFORMER_CHECKPOINT=SongFormer.safetensors
SONGFORMER_CONFIG=SongFormer.yaml

# ChordMini runtime/model directory.
# Point this to ChordMiniApp/python_backend/models/ChordMini or an equivalent copy.
CHORDCRAFT_CHORDMINI_DIR=

# Optional explicit ffmpeg/ffprobe paths.
CHORDCRAFT_FFMPEG=
CHORDCRAFT_FFPROBE=
